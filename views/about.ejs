<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About - GorillaGrills</title>

    <link rel="stylesheet" href="/css/about.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <div class="navbar">
        <div class="logo">GorillaGrills</div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/menu">Menu</a>
        </div>
    </div>

    <!-- HERO -->
    <div class="hero">
        <div class="overlay">
            <h1>Our Story 🦍🔥</h1>
        </div>
    </div>

    <!-- SECTION 1 -->
    <div class="section">
        <div class="text">
            <h2>Who We Are</h2>
            <p>
                GorillaGrills is more than just a restaurant — it's a place where 
                bold flavors meet modern technology. We focus on delivering fast, 
                delicious meals with a seamless ordering experience.
            </p>
        </div>
        <div class="image">
            <img src="/images/about1.jpeg">
        </div>
    </div>

    <!-- PARALLAX SECTION -->
    <div class="parallax">
        <div class="overlay-text">
            <h2>Grilled to Perfection 🔥</h2>
        </div>
    </div>

    <!-- SECTION 2 -->
    <div class="section reverse">
        <div class="image">
            <img src="/images/about2.jpeg">
        </div>
        <div class="text">
            <h2>Our Mission</h2>
            <p>
                Our mission is to redefine dining by combining great taste with 
                smart ordering systems like QR-based menus and quick service.
            </p>
        </div>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        <p>© 2026 GorillaGrills. All rights reserved.</p>
    </div>

</body>
</html>