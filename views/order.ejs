<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Order Online - GorillaGrills</title>

    <link rel="stylesheet" href="/css/order.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>

    <!-- NAVBAR -->
    <div class="navbar">
        <div class="logo">🦍 GorillaGrills</div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/menu">Menu</a>
            <a href="/order" class="active">Order</a>
        </div>
    </div>

    <!-- HERO -->
    <div class="order-hero">
        <div class="bg-slider"></div> 
        <div class="overlay">
            <h1>Order Online</h1>
            <p>You can order online! Choose your favorite meals.</p>

            <div class="status">🟢 Accepting Orders</div>

            <button class="pickup-btn">Pickup</button>

            <div class="info">
                ⏱ Pickup: 30 mins &nbsp; | &nbsp; 📍 GorillaGrills, Sirsa
            </div>
        </div>
    </div>

    <!-- MENU LIST -->
    <div class="menu-list">

        <h2>🔥 Our Menu</h2>

        <% const items = [
            {name:"Cheese Burger", price:180},
            {name:"Chicken Burger", price:200},
            {name:"Veg Burger", price:150},
            {name:"Hot Dog", price:140},
            {name:"Pizza", price:300},
            {name:"Pasta", price:250},
            {name:"French Fries", price:110},
            {name:"Nuggets", price:160},
            {name:"Sandwich", price:120},
            {name:"Grilled Chicken", price:350},
            {name:"Milkshake", price:90},
            {name:"Cold Coffee", price:100},
            {name:"Lemon Tea", price:70},
            {name:"Orange Juice", price:80},
            {name:"Mocktail", price:120}
        ]; %>

        <% items.forEach(item => { %>
            <div class="menu-item">
                <div>
                    <h3><%= item.name %></h3>
                    <span>₹ <%= item.price %></span>
                </div>

                <button class="add-btn">Add</button>
            </div>
        <% }) %>

    </div>

</body>
</html>